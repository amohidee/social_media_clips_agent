{
  "name": "islamic-media-worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create islamic-media-db",
    "db:migrate": "wrangler d1 execute islamic-media-db --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute islamic-media-db --local --file=schema.sql"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250430.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.0.0"
  }
}
